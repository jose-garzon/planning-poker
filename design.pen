          "fontFamily": "Bricolage Grotesque",
          "fontSize": 11,
          "fontWeight": "900"
        },
        {
          "type": "text",
          "id": "VotMob3AnnotDesc",
          "fill": "#9CA3AF",
          "content": "• Timer ring: #FFB800→#EF4444 (400ms ease-in-out at 30s threshold)\n• Ring fill: transparent→#2D0A0A (dark red tint)\n• Timer pulse: scale 1.0→1.05→1.0 every 800ms loop\n• Red glow: 0 0 12px #EF4444 (box-shadow)\n• Deck label and card text dim to #64748B\n• Story card: 1px #EF4444 urgency border\n• prefers-reduced-motion: static red ring only",
          "fontFamily": "Bricolage Grotesque",
          "fontSize": 10,
          "fontWeight": "normal"
        }
      ]
    }
