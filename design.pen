              "fontFamily": "Bricolage Grotesque",
              "fontSize": 12,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "5IJXG",
              "name": "desc1",
              "fill": "#9CA3AF",
              "content": "• Duration: 2 second infinite loop\n• Effect: Opacity pulse (0.6 → 1.0 → 0.6)\n• Color: Green (#00FF88) only\n• Trigger: Applied to all online participants' status dots",
              "fontFamily": "Bricolage Grotesque",
              "fontSize": 10,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "tCzSY",
          "name": "section2",
          "width": "fill_container",
