              "name": "label2",
              "fill": "#00FF88",
              "content": "2. NEW PARTICIPANT ENTRANCE",
              "fontFamily": "Bricolage Grotesque",
              "fontSize": 12,
              "fontWeight": "700"
            },
            {
              "type": "text",
              "id": "D1gSV",
              "name": "desc2",
              "fill": "#9CA3AF",
              "content": "• Duration: 150ms\n• Easing: ease-out\n• Motion: Slide from top (Y: -20px → 0) + Fade-in (0 → 1)\n• Trigger: When a new participant joins the session",
              "fontFamily": "Bricolage Grotesque",
              "fontSize": 10,
              "fontWeight": "normal"
            }
          ]
        },
